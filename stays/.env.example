# Nexa Stays — port 3002
# Copy to .env and fill values. Never commit .env.
PORT=3002
API_PREFIX=api/v1
NODE_ENV=development

DB_HOST=localhost
DB_PORT=5434
DB_USERNAME=nexa_stays
# Local docker-compose default only — use a strong unique password in production
DB_PASSWORD=nexa_stays_dev
DB_NAME=nexa_stays
DB_SYNCHRONIZE=false

IDENTITY_BASE_URL=http://127.0.0.1:3001/api/v1
IDENTITY_JWKS_URL=http://127.0.0.1:3001/api/v1/.well-known/jwks.json

STAYS_PAYMENT_PROVIDER=mock
STAYS_PUBLIC_URL=http://127.0.0.1:3002
STAYS_WEB_URL=http://127.0.0.1:3000

# CMI — server-only secrets; required when STAYS_PAYMENT_PROVIDER=cmi
CMI_CLIENT_ID=
CMI_STORE_KEY=
CMI_CALLBACK_URL=http://127.0.0.1:3002/api/v1/stays/webhooks/payments/cmi

CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000

REDIS_URL=redis://127.0.0.1:6379
NOTIFICATIONS_SERVICE_URL=http://127.0.0.1:3003
# Shared with platform services — use a long random value in production
INTERNAL_SERVICE_KEY=dev-internal-key

# Observability / incident routing
# OTEL_EXPORTER_OTLP_ENDPOINT=https://otel-collector.example.com/v1/traces
# ERROR_MONITORING_DSN=
# PAYMENT_ALERT_WEBHOOK_URL=
# OPS_ALERT_EMAIL=ops@nexastays.com

# Abuse / secure deployment
# ENFORCE_BOT_PROTECTION=true
# ALLOW_SCRIPT_CLIENTS=false
# TRUST_PROXY=true
# TRUST_PROXY_HOPS=1
# ENFORCE_HTTPS=true
# ENABLE_SWAGGER=false
# SECURITY_AUTH_FAIL_BURST=20
# SECURITY_RATE_LIMIT_BURST=30
IDENTITY_SNAPSHOT_TTL_MS=120000

# Default platform fees (decimal). Overridden by stays_platform_settings after migration.
STAYS_GUEST_FEE_PCT=0.05
STAYS_HOST_FEE_PCT=0.05
