						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"phone_number\": \"+212612345678\",\n  \"otp\": \"123456\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/auth/otp/verify",
							"host": ["{{base_url}}"],
							"path": ["auth", "otp", "verify"]
