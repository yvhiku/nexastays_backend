				{
					"name": "Send OTP",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 200', function () {",
									"    pm.response.to.have.status(200);",
									"});"
								]
							}
						}
					],
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"phone_number\": \"+212612345678\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/auth/otp/send",
							"host": ["{{base_url}}"],
							"path": ["auth", "otp", "send"]
						}
					}
				},
				{
					"name": "Verify OTP",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"var jsonData = pm.response.json();",
									"if (jsonData.data && jsonData.data.otp_session_token) {",
									"    pm.collectionVariables.set('otp_session_token', jsonData.data.otp_session_token);",
									"} else if (jsonData.otp_session_token) {",
									"    pm.collectionVariables.set('otp_session_token', jsonData.otp_session_token);",
									"}"
								]
							}
						}
					],
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "POST",
