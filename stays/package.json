{
  "name": "@nexa/stays",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "npm run build && node dist/main",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "db:up": "docker compose -f ../../database/stays/docker-compose.yml up -d",
    "db:down": "docker compose -f ../../database/stays/docker-compose.yml down",
    "db:migrate": "powershell -ExecutionPolicy Bypass -File ../../database/stays/migrate.ps1",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "audit": "npm audit --audit-level=high",
    "audit:osv": "npx --yes @google/osv-scanner@latest -r . || npx --yes osv-scanner@latest -r .",
    "audit:trivy": "trivy fs --severity HIGH,CRITICAL --exit-code 1 .",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "seed:listings": "npx ts-node -r tsconfig-paths/register src/scripts/seed-morocco-listings.ts",
    "seed:bookings": "npx ts-node -r tsconfig-paths/register src/scripts/seed-random-bookings.ts",
    "seed:taxi": "npx ts-node -r tsconfig-paths/register src/scripts/seed-taxi-test-data.ts",
    "seed:food": "npx ts-node -r tsconfig-paths/register src/scripts/seed-food-test-data.ts",
    "test:taxi": "npx ts-node scripts/test-taxi-ride.ts",
    "test:food": "npx ts-node scripts/test-food-order.ts",
    "test:endpoints": "npx ts-node -r tsconfig-paths/register scripts/test-endpoints.ts",
    "check:taxi-tx": "npx ts-node -r tsconfig-paths/register scripts/check-taxi-transactions.ts",
    "backfill:taxi-tx": "npx ts-node -r tsconfig-paths/register scripts/backfill-taxi-transactions.ts",
    "migrate:docker": "powershell -ExecutionPolicy Bypass -File ./scripts/migrate-docker-db.ps1",
    "migrate:docker:baseline": "powershell -ExecutionPolicy Bypass -File ./scripts/migrate-docker-db.ps1 -Baseline",
    "migrate:docker:file": "powershell -ExecutionPolicy Bypass -File ./scripts/migrate-docker-db.ps1 -File"
  },
  "dependencies": {
    "@nestjs/cache-manager": "^2.0.0",
    "@nestjs/common": "^11.1.18",
    "@nestjs/core": "^11.1.27",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.18",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.2.5",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.3",
    "@nexa/event-bus": "file:../../platform/event-bus",
    "@nexa/identity-read-model": "file:../../platform/identity-read-model",
    "@nexa/telemetry": "file:../../platform/telemetry",
    "@types/pdfkit": "^0.17.5",
    "argon2": "^0.44.0",
    "bcrypt": "^6.0.0",
    "cache-manager": "^7.2.8",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "dotenv": "^17.3.1",
    "helmet": "^8.1.0",
    "jwks-rsa": "^3.2.0",
    "multer": "2.2.0",
    "node-ical": "^0.26.1",
    "openai": "^6.37.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pdfkit": "^0.17.2",
    "pg": "^8.17.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "twilio": "^5.12.2",
    "typeorm": "^0.3.28"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.1.27",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.10.7",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "overrides": {
    "multer": "2.2.0",
    "axios": ">=1.15.0",
    "follow-redirects": ">=1.15.12",
    "protobufjs": ">=7.5.5",
    "uuid": ">=14.0.0",
    "ajv": ">=8.18.0",
    "file-type": ">=21.3.2",
    "@tootallnate/once": ">=3.0.1",
    "lodash": "4.18.1",
    "path-to-regexp": "8.4.2",
    "picomatch": "4.0.4",
    "handlebars": "4.7.9",
    "fast-xml-parser": ">=5.7.0",
    "fast-xml-builder": ">=1.2.0",
    "fast-uri": ">=3.1.2",
    "flatted": ">=3.4.2",
    "node-forge": ">=1.4.0",
    "@nestjs/swagger": {
      "path-to-regexp": "8.4.2",
      "lodash": "4.18.1"
    },
    "ts-jest": {
      "handlebars": "4.7.9"
    },
    "minimatch@3.1.5": {
      "brace-expansion": "1.1.13"
    }
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "transformIgnorePatterns": [
      "node_modules/(?!(uuid)/)"
    ]
  }
}
