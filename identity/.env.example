# Nexa Identity (SSO) — port 3001
# Copy to .env and fill values. Never commit .env.
NODE_ENV=development
PORT=3001
API_PREFIX=api/v1

# Database (see database/identity/migrations)
DB_HOST=localhost
DB_PORT=5433
DB_USERNAME=nexa_identity
# Local docker-compose default only — use a strong unique password in production
DB_PASSWORD=nexa_identity_dev
DB_NAME=nexa_identity

# JWT — RS256 (auto-generated key pair in dev if unset; REQUIRED in production)
JWT_KEY_ID=nexa-identity-1
# JWT_PRIVATE_KEY=
# JWT_PUBLIC_KEY=
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=604800
# REFRESH_TOKEN_PEPPER=
# OTP_PEPPER=
# KYC_HASH_PEPPER=

# Demo OTP (dev only — must be unset in production)
DEMO_OTP_CODE=123456
OTP_EXPIRY_SECONDS=300

# Admin bootstrap — prefer ADMIN_PASSWORD_HASH (Argon2id) over plaintext
ADMIN_EMAILS=
# ADMIN_PASSWORD_HASH=
ADMIN_PASSWORD=

# Sumsub KYC — server-only; never expose to NEXT_PUBLIC_* or frontend
SUMSUB_APP_TOKEN=
SUMSUB_SECRET_KEY=
SUMSUB_WEBHOOK_SECRET=
SUMSUB_BASE_URL=https://api.sumsub.com
SUMSUB_LEVEL_NAME=basic-kyc-level
SUMSUB_TOKEN_TTL_SECONDS=600

CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000,http://127.0.0.1:3005,http://localhost:3005,http://127.0.0.1:3010,http://localhost:3010

REDIS_URL=redis://127.0.0.1:6379
IDENTITY_SNAPSHOT_TTL_MS=120000
NOTIFICATIONS_SERVICE_URL=http://127.0.0.1:3003
# Shared with platform services — use a long random value in production
INTERNAL_SERVICE_KEY=dev-internal-key

# Abuse / secure deployment
# ENFORCE_BOT_PROTECTION=true
# ALLOW_SCRIPT_CLIENTS=false
# TRUST_PROXY=true
# TRUST_PROXY_HOPS=1
# ENFORCE_HTTPS=true
# ENABLE_SWAGGER=false
# SECURITY_AUTH_FAIL_BURST=20
# SECURITY_RATE_LIMIT_BURST=30
